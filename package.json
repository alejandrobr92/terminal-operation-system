{
  "name": "tos",
  "version": "1.0.0",
  "description": "Terminal Operation System microfrontend workspace",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "dev:shell": "pnpm --filter ./apps/shell dev",
    "dev:yard": "pnpm --filter ./apps/mfe-yard dev",
    "dev:planning": "pnpm --filter ./apps/mfe-planning dev",
    "dev:analytics": "pnpm --filter ./apps/mfe-analytics dev",
    "test": "vitest run"
  },
  "packageManager": "pnpm@10.28.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
